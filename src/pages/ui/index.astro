      </div>
    </section>
  </div>
</SiteLayout>

<script is:inline>
  (function () {
    var root = document.getElementById('ui-tabs');
    if (!root) return;
    var out = root.querySelector('[data-tabs-out]');
    root.querySelectorAll('[data-tab]').forEach(function (tab) {
      tab.addEventListener('click', function () {
        root.querySelectorAll('[data-tab]').forEach(function (t) { t.classList.remove('cn-tab--active'); });
        tab.classList.add('cn-tab--active');
        if (out) out.textContent = tab.getAttribute('data-label');
      });
    });
  })();
</script>

