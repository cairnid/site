---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Icon from '../../components/Icon.astro';
import CairnMark from '../../components/CairnMark.astro';
import Banner from '../../components/ui/Banner.astro';
import Button from '../../components/ui/Button.astro';
import Card from '../../components/ui/Card.astro';
import Chip from '../../components/ui/Chip.astro';
import IconButton from '../../components/ui/IconButton.astro';
import Pill from '../../components/ui/Pill.astro';

const stoneScale = [
  { n: '0', hex: '#ffffff' }, { n: '25', hex: '#faf8f3' }, { n: '50', hex: '#f4f1ea' },
  { n: '100', hex: '#ece7dd' }, { n: '150', hex: '#e2dccf' }, { n: '200', hex: '#d4cdbd' },
  { n: '300', hex: '#bbb2a0' }, { n: '400', hex: '#97907f' }, { n: '500', hex: '#756e5f' },
  { n: '600', hex: '#585143' }, { n: '900', hex: '#1b1813' },
];
const tealScale = [
  { n: '50', hex: '#e3f1ec' }, { n: '100', hex: '#c4e3da' }, { n: '200', hex: '#93ccbc' },
  { n: '300', hex: '#4fb29a' }, { n: '400', hex: '#1ea487' }, { n: '500', hex: '#12876f' },
  { n: '600', hex: '#0c6052' }, { n: '700', hex: '#094a3f' },
];
const spacing = [
  ['1', '4px'], ['2', '8px'], ['3', '12px'], ['4', '16px'],
  ['5', '20px'], ['6', '24px'], ['7', '32px'], ['8', '40px'],
];
const iconNames = [
  'activity', 'app-window', 'arrow-right', 'badge-check', 'ban', 'boxes', 'check', 'check-circle-2',
  'chevrons-up-down', 'cloud', 'copy', 'credit-card', 'database-backup', 'download', 'ellipsis-vertical',
  'file-text', 'filter', 'fingerprint', 'gauge', 'git-branch', 'github', 'globe', 'info', 'key-round',
  'layout-dashboard', 'life-buoy', 'lock', 'lock-keyhole', 'log-in', 'monitor-smartphone', 'moon',
  'pencil', 'plus', 'refresh-cw', 'scroll-text', 'search', 'server', 'settings', 'shield', 'shield-check',
  'smartphone', 'sun', 'terminal', 'timer', 'triangle-alert', 'user-plus', 'user-round-cog', 'users',
  'x', 'x-circle',
];
const tabs = [
  { id: 'sessions', label: 'Sessions' },
  { id: 'apps', label: 'Authorized apps' },
  { id: 'mfa', label: 'Two-factor' },
  { id: 'recovery', label: 'Recovery codes' },
];
---

<SiteLayout
  title="Design system"
  description="The CairnID design system, built in Astro: brand, color, type, spacing, and the cn- component library - warm granite neutrals, one teal accent, Archivo + JetBrains Mono."
>
  <section class="ui-head">
    <div class="wrap">
      <div class="eyebrow">Design system</div>
      <h1>The instrument, documented</h1>
      <p>Every token and component CairnID is built from - warm granite neutrals, one teal accent, Archivo for everything human-readable, and JetBrains Mono for machine values. Calm, exact, trustworthy. Toggle the theme in the masthead to see both modes.</p>
    </div>
  </section>

  <div class="wrap ui-body">
    <!-- ============ BRAND ============ -->
    <section class="ui-section" id="brand">
      <div class="ui-section__title"><span class="no">01</span>Brand</div>
      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Logo &amp; wordmark</div><div class="sub">Cairn mark + Archivo wordmark, light and dark</div></div>
        <div class="spec-card__demo brand-demo">
          <div class="brand-cell light">
            <div class="lockup"><CairnMark size={38} /><span class="word">Cairn<span class="id">ID</span></span></div>
          </div>
          <div class="brand-cell dark theme-dark">
            <div class="lockup"><CairnMark size={38} /><div><span class="word">Cairn<span class="id">ID</span></span><span class="brand-tag">Strict OIDC. Clear operations.</span></div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ COLOR ============ -->
    <section class="ui-section" id="color">
      <div class="ui-section__title"><span class="no">02</span>Color</div>

      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Granite neutrals</div><div class="sub">Warm stone grays carry ~90% of the UI</div></div>
        <div class="spec-card__demo card-bg">
          <div class="scale scale--11">
            {stoneScale.map((s) => (
              <div class="sw"><div class="chip" style={`background:${s.hex}`}></div><div class="name">{s.n}</div><div class="hex">{s.hex}</div></div>
            ))}
          </div>
        </div>
      </div>

      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Teal accent - the cairn</div><div class="sub">One accent. Used sparingly, it always means act here.</div></div>
        <div class="spec-card__demo card-bg">
          <div class="scale scale--8">
            {tealScale.map((s) => (
              <div class="sw"><div class="chip" style={`background:${s.hex}`}></div><div class="name">{s.n}</div><div class="hex">{s.hex}</div></div>
            ))}
          </div>
          <div class="accent-use">
            <Button variant="primary" size="sm">Approve</Button>
            <a class="accent-link" href="#color">Review consent</a>
            <span class="note">600 fills primary actions - 400 brightens for dark mode &amp; focus</span>
          </div>
        </div>
      </div>

      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Semantic state</div><div class="sub">Color only for real state - success, caution, danger</div></div>
        <div class="spec-card__demo card-bg">
          <div class="sem-grid">
            <div class="sem s"><h4>Success</h4><p>Passkey enrolled. Recovery codes regenerated.</p></div>
            <div class="sem c"><h4>Caution</h4><p>This action signs out every active session.</p></div>
            <div class="sem d"><h4>Danger</h4><p>Disabling revokes all issued tokens. This cannot be undone.</p></div>
          </div>
        </div>
      </div>

      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Surfaces - light &amp; dark</div><div class="sub">Both themes warm; dark is charcoal granite, never pure black</div></div>
        <div class="spec-card__demo surf-demo">
          <div class="surf-pane light">
            <div class="surf-lbl">Light</div>
            <div class="surf-stack">
              <div class="surf-row"><span class="surf-box" style="background:var(--stone-25)"></span><span class="surf-nm">page</span></div>
              <div class="surf-row"><span class="surf-box" style="background:var(--stone-0)"></span><span class="surf-nm">card</span></div>
              <div class="surf-row"><span class="surf-box" style="background:var(--stone-50)"></span><span class="surf-nm">sunken</span></div>
              <div class="surf-row"><span class="surf-box" style="background:#eef4f1"></span><span class="surf-nm">selected</span></div>
            </div>
          </div>
          <div class="surf-pane dark theme-dark">
            <div class="surf-lbl">Dark</div>
            <div class="surf-stack">
              <div class="surf-row"><span class="surf-box" style="background:var(--surface-page)"></span><span class="surf-nm">page</span></div>
              <div class="surf-row"><span class="surf-box" style="background:var(--surface-card)"></span><span class="surf-nm">card</span></div>
              <div class="surf-row"><span class="surf-box" style="background:var(--surface-raised)"></span><span class="surf-nm">raised</span></div>
              <div class="surf-row"><span class="surf-box" style="background:var(--surface-selected)"></span><span class="surf-nm">selected</span></div>
            </div>
          </div>
        </div>
      </div>

      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Status pills</div><div class="sub">A small fixed set - active, revoked, disabled</div></div>
        <div class="spec-card__demo card-bg pill-row">
          <Pill tone="active" dot>Active</Pill>
          <Pill tone="revoked" dot>Revoked</Pill>
          <Pill tone="disabled" dot>Disabled</Pill>
          <span class="note">No badge confetti - these three carry every state.</span>
        </div>
      </div>
    </section>

    <!-- ============ TYPE ============ -->
    <section class="ui-section" id="type">
      <div class="ui-section__title"><span class="no">03</span>Type</div>

      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Headings - Archivo</div><div class="sub">Hierarchy from weight + structure, not size alone</div></div>
        <div class="spec-card__demo card-bg">
          <div class="type-row"><div class="type-spec">Display - 34 / 700</div><div class="t-d">Verify the path</div></div>
          <div class="type-row"><div class="type-spec">H1 - 26 / 600</div><div class="t-h1">Applications</div></div>
          <div class="type-row"><div class="type-spec">H2 - 20 / 600</div><div class="t-h2">Authorized applications</div></div>
          <div class="type-row"><div class="type-spec">H3 - 16 / 600</div><div class="t-h3">Redirect URIs</div></div>
          <div class="type-row"><div class="type-spec">Label - 11 / 600</div><div class="t-lbl">Client status</div></div>
        </div>
      </div>

      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Body &amp; UI text</div><div class="sub">Archivo at reading sizes - primary, secondary, muted</div></div>
        <div class="spec-card__demo card-bg type-body">
          <div><div class="type-spec">Body - 14 / 400</div><p class="t-body">Disabling this client immediately invalidates its authorization codes and revokes every issued access and refresh token. Users will be asked to sign in again.</p></div>
          <div><div class="type-spec">Secondary - 13 / 400</div><p class="t-sec">Register OIDC clients with exact redirect URIs and PKCE enabled.</p></div>
          <div><div class="type-spec">Muted / meta - 12 / 400</div><p class="t-muted">Last verified 4 minutes ago - 3 active sessions</p></div>
        </div>
      </div>

      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Machine values - JetBrains Mono</div><div class="sub">Mono only for IDs, tokens, hashes, URIs - never prose</div></div>
        <div class="spec-card__demo card-bg mono-demo">
          <div class="mono-line"><span class="mk">Client ID</span><span class="mv">cln_7Q2f9aE4kV0pX1mB</span></div>
          <div class="mono-line"><span class="mk">Redirect URI</span><span class="mv">https://app.example.com/callback</span></div>
          <div class="mono-line"><span class="mk">Token (jti)</span><span class="mv">a3F8.eyJhbGciOiJSUzI1Ni ... 9Lx0wQ</span></div>
          <div class="mono-line"><span class="mk">Key hash</span><span class="mv">SHA-256:0xC0FFEE-48b1-a09f-3D7e</span></div>
          <div class="mono-line"><span class="mk">Event ID</span><span class="mv">evt_01J9Z6KQ8R4N2C0V</span></div>
        </div>
      </div>
    </section>

    <!-- ============ SPACING ============ -->
    <section class="ui-section" id="spacing">
      <div class="ui-section__title"><span class="no">04</span>Spacing &amp; elevation</div>

      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Spacing scale</div><div class="sub">4px base - whitespace for hierarchy, never decoration</div></div>
        <div class="spec-card__demo card-bg space-demo">
          {spacing.map(([n, px]) => (
            <div class="space-row"><span class="space-t">{n} - {px}</span><span class="space-bar" style={`width:${px}`}></span></div>
          ))}
        </div>
      </div>

      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Radius &amp; elevation</div><div class="sub">Small engineered radii, restrained warm-cast shadows</div></div>
        <div class="spec-card__demo re-demo">
          <div class="re-group">
            <div class="re-item"><div class="re-box" style="border-radius:3px"></div><span class="re-t">xs 3</span></div>
            <div class="re-item"><div class="re-box" style="border-radius:5px"></div><span class="re-t">sm 5</span></div>
            <div class="re-item"><div class="re-box" style="border-radius:7px"></div><span class="re-t">md 7</span></div>
            <div class="re-item"><div class="re-box" style="border-radius:10px"></div><span class="re-t">lg 10</span></div>
          </div>
          <div class="re-div"></div>
          <div class="re-group">
            <div class="re-item"><div class="re-box re-sh" style="box-shadow:var(--shadow-sm);border-radius:7px"></div><span class="re-t">sm</span></div>
            <div class="re-item"><div class="re-box re-sh" style="box-shadow:var(--shadow-md);border-radius:7px"></div><span class="re-t">md</span></div>
            <div class="re-item"><div class="re-box re-sh" style="box-shadow:var(--shadow-lg);border-radius:7px"></div><span class="re-t">lg</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ COMPONENTS ============ -->
    <section class="ui-section" id="components">
      <div class="ui-section__title"><span class="no">05</span>Components</div>

      <!-- Forms -->
      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Forms</div><div class="sub">Buttons, inputs, select, checkbox, switch</div></div>
        <div class="spec-card__demo">
          <div class="cmp-grid">
            <div class="cmp-seg">
              <span class="cap">Buttons</span>
              <div class="cmp-row">
                <Button variant="primary" icon="shield-check">Approve</Button>
                <Button>Cancel</Button>
                <Button variant="ghost">Details</Button>
                <Button variant="danger" icon="ban">Disable</Button>
                <Button variant="primary" busy>Saving</Button>
                <Button disabled>Disabled</Button>
              </div>
              <div class="cmp-row">
                <Button variant="primary" size="sm">Small</Button>
                <Button size="sm">Small</Button>
                <Button variant="outline" size="lg">Large outline</Button>
                <IconButton icon="refresh-cw" label="Refresh" />
                <IconButton icon="ellipsis-vertical" label="More" variant="ghost" />
              </div>
            </div>
            <div class="cmp-cols">
              <div class="cn-field">
                <label class="cn-field__label" for="ui-n">Client name</label>
                <input class="cn-input" id="ui-n" value="Billing Portal" />
                <span class="cn-field__hint">Shown to users on the consent screen.</span>
              </div>
              <div class="cn-field">
                <label class="cn-field__label" for="ui-r">Redirect URI</label>
                <input class="cn-input cn-input--mono" id="ui-r" value="https://app.example.com/callback" />
              </div>
              <div class="cn-field">
                <label class="cn-field__label" for="ui-p">Consent policy</label>
                <select class="cn-select" id="ui-p">
                  <option>Required once</option>
                  <option>Required each time</option>
                  <option>Trusted - skip</option>
                </select>
              </div>
              <div class="cn-field">
                <label class="cn-field__label" for="ui-s">Search</label>
                <div class="cn-input-group"><span class="cn-input-group__icon"><Icon name="search" size={15} /></span><input class="cn-input" id="ui-s" aria-label="Search users" /></div>
              </div>
            </div>
            <div class="cmp-row cmp-row--wide">
              <label class="cn-check"><input type="checkbox" checked /><span class="cn-check__box"><Icon name="check" class="cn-check__tick" /></span>Public client (PKCE)</label>
              <label class="cn-check"><input type="checkbox" data-indeterminate="true" /><span class="cn-check__box"><span class="cn-check__line"></span></span>Some groups selected</label>
              <label class="cn-check"><input type="radio" name="ui-radio" checked /><span class="cn-check__box cn-check__box--radio"><span class="cn-check__dot"></span></span>OIDC client</label>
              <label class="cn-switch"><input type="checkbox" checked /><span class="cn-switch__track"><span class="cn-switch__thumb"></span></span>Active</label>
            </div>
          </div>
        </div>
      </div>

      <!-- Data display -->
      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Data display</div><div class="sub">Status pills, chips, copy fields, cards, tables</div></div>
        <div class="spec-card__demo">
          <div class="cmp-grid">
            <div>
              <div class="cap">Status pills &amp; chips</div>
              <div class="cmp-row">
                <Pill tone="active" dot>Active</Pill>
                <Pill tone="revoked" dot>Revoked</Pill>
                <Pill tone="disabled" dot>Disabled</Pill>
                <Chip mono>openid</Chip>
                <Chip mono>profile</Chip>
                <Chip mono removable>email</Chip>
              </div>
            </div>
            <div>
              <div class="cap">Copy field</div>
              <span class="cn-copyfield"><span class="cn-copyfield__value">cln_7Q2f9aE4kV0pX1mB</span><button class="cn-copyfield__btn" type="button"><Icon name="copy" size={11} />Copy</button></span>
            </div>
            <Card bodyClass="pt-0">
              <Fragment slot="header">
                <div><div class="cn-card__title">Applications</div><div class="cn-card__subtitle">3 registered clients</div></div>
                <Button size="sm">New</Button>
              </Fragment>
                <table class="cn-table cn-table--num">
                  <thead><tr><th>Application</th><th>Client ID</th><th>Scopes</th><th>Status</th></tr></thead>
                  <tbody>
                    <tr><td style="font-weight:500">Billing Portal</td><td class="mono" style="color:var(--text-secondary)">cln_7Q2f9aE4</td><td><div class="cmp-row" style="gap:5px"><span class="cn-chip cn-chip--mono">openid</span><span class="cn-chip cn-chip--mono">profile</span></div></td><td><span class="cn-pill cn-pill--active"><span class="cn-pill__dot"></span>Active</span></td></tr>
                    <tr><td style="font-weight:500">CI Runner</td><td class="mono" style="color:var(--text-secondary)">cln_b3K9zR1p</td><td><div class="cmp-row" style="gap:5px"><span class="cn-chip cn-chip--mono">openid</span><span class="cn-chip cn-chip--mono">groups</span></div></td><td><span class="cn-pill cn-pill--disabled"><span class="cn-pill__dot"></span>Disabled</span></td></tr>
                    <tr><td style="font-weight:500">Legacy Sync</td><td class="mono" style="color:var(--text-secondary)">cln_44Xc0Te2</td><td><div class="cmp-row" style="gap:5px"><span class="cn-chip cn-chip--mono">openid</span></div></td><td><span class="cn-pill cn-pill--revoked"><span class="cn-pill__dot"></span>Revoked</span></td></tr>
                  </tbody>
                </table>
            </Card>
          </div>
        </div>
      </div>

      <!-- Feedback -->
      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Feedback</div><div class="sub">Inline banners and the confirmation dialog</div></div>
        <div class="spec-card__demo">
          <div class="fb-grid">
            <Banner tone="success" icon="shield-check" title="Passkey enrolled">Store your recovery codes now - they are shown once.</Banner>
            <Banner tone="caution" icon="lock-keyhole" title="Reauthentication required">Confirm your identity to change this password.</Banner>
            <Banner tone="danger" icon="triangle-alert" title="Secret rotation failed">The client secret was not rotated. No tokens were affected.</Banner>
            <Banner icon="info">Disabled clients keep their registration and can be reactivated.</Banner>

            <div class="dialog-stage">
              <div class="cn-dialog" style="box-shadow:var(--shadow-lg);">
                <div class="cn-dialog__header">
                  <span class="cn-dialog__icon cn-dialog__icon--danger"><Icon name="triangle-alert" size={18} /></span>
                  <div><div class="cn-dialog__title">Disable Billing Portal?</div></div>
                </div>
                <div class="cn-dialog__body cn-dialog__body--inset">This immediately invalidates its authorization codes and revokes every issued access and refresh token. Users will be asked to sign in again. This cannot be undone.</div>
                <div class="cn-dialog__footer">
                  <Button variant="ghost">Cancel</Button>
                  <Button variant="danger">Disable client</Button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Navigation -->
      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Navigation - Tabs</div><div class="sub">Underline tab bar for in-screen sections</div></div>
        <div class="spec-card__demo card-bg">
          <div class="tabs-panel" id="ui-tabs">
            <div class="cn-tabs" role="tablist">
              {tabs.map((t) => (
                <button class={`cn-tab${t.id === 'apps' ? ' cn-tab--active' : ''}`} type="button" role="tab" data-tab={t.id} data-label={t.label}>{t.label}</button>
              ))}
            </div>
            <div class="tabs-body">Showing: <span data-tabs-out>Authorized apps</span></div>
          </div>
        </div>
      </div>

      <!-- Interaction primitives -->
      <div class="spec-card">
        <div class="spec-card__head"><div class="nm">Interaction primitives</div><div class="sub">Motion-rich states, restrained by CairnID tokens and available as reusable cn- patterns</div></div>
        <div class="spec-card__demo">
          <div class="interaction-grid">
            <div class="cmp-seg">
              <span class="cap">Segmented tabs &amp; tooltip</span>
              <div class="cmp-row">
                <div class="cn-tabs cn-tabs--segment" role="tablist" aria-label="Client type">
                  <button class="cn-tab cn-tab--active" type="button" role="tab">Confidential</button>
                  <button class="cn-tab" type="button" role="tab">Public</button>
                  <button class="cn-tab" type="button" role="tab">Device</button>
                </div>
                <span class="cn-tooltip">
                  <IconButton icon="info" label="Explain client type" variant="ghost" />
                  <span class="cn-tooltip__bubble">Confidential clients can hold a secret.</span>
                </span>
              </div>
            </div>

            <div class="cmp-seg">
              <span class="cap">OTP input</span>
              <div class="cn-otp" aria-label="One-time code">
                <input class="cn-otp__cell" inputmode="numeric" maxlength="1" value="4" aria-label="Digit 1" />
                <input class="cn-otp__cell" inputmode="numeric" maxlength="1" value="8" aria-label="Digit 2" />
                <input class="cn-otp__cell" inputmode="numeric" maxlength="1" value="1" aria-label="Digit 3" />
                <input class="cn-otp__cell" inputmode="numeric" maxlength="1" aria-label="Digit 4" />
                <input class="cn-otp__cell" inputmode="numeric" maxlength="1" aria-label="Digit 5" />
                <input class="cn-otp__cell" inputmode="numeric" maxlength="1" aria-label="Digit 6" />
              </div>
            </div>

            <div class="cmp-seg">
              <span class="cap">Command palette</span>
              <div class="cn-command">
                <div class="cn-command__search"><Icon name="search" size={16} /><input class="cn-command__input" value="rotate" aria-label="Command search" /></div>
                <div class="cn-command__list">
                  <div class="cn-command__item" aria-selected="true"><Icon name="key-round" size={16} /><span>Rotate client secret</span><kbd class="cn-command__kbd">Enter</kbd></div>
                  <div class="cn-command__item"><Icon name="download" size={16} /><span>Export audit events</span><kbd class="cn-command__kbd">E</kbd></div>
                  <div class="cn-command__item"><Icon name="user-plus" size={16} /><span>Invite user</span><kbd class="cn-command__kbd">I</kbd></div>
                </div>
              </div>
            </div>

            <div class="cmp-seg">
              <span class="cap">Action bar &amp; overflow</span>
              <div class="action-demo">
                <div class="cn-action-bar" aria-label="Application actions">
                  <IconButton icon="pencil" label="Edit" variant="ghost" size="sm" />
                  <IconButton icon="copy" label="Copy client ID" variant="ghost" size="sm" />
                  <span class="cn-action-bar__divider"></span>
                  <IconButton icon="ellipsis-vertical" label="More actions" variant="ghost" size="sm" />
                </div>
                <div class="cn-overflow">
                  <button class="cn-overflow__item" type="button"><Icon name="refresh-cw" size={15} />Rotate secret</button>
