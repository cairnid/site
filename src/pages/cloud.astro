---
import SiteLayout from '../layouts/SiteLayout.astro';
import Icon from '../components/Icon.astro';
import GemMark from '../components/GemMark.tsx';

const features = [
  { icon: 'refresh-cw', h: 'Release guidance', p: 'Track upgrade notes, release gates, and operational checks before exposing a public issuer.' },
  { icon: 'server', h: 'Self-hosted source', p: 'Run the reviewed source on your own infrastructure with Docker Compose or locally built containers.' },
  { icon: 'database-backup', h: 'Backup and restore drills', p: 'Use the documented Postgres backup, restore-check, signing-key, and KEK procedures.' },
  { icon: 'activity', h: 'Evidence-first operations', p: 'Preflight, smoke commands, and release-evidence checks show what is ready and what is still blocked.' },
  { icon: 'git-branch', h: 'Release artifacts', p: 'CLI and MCP archives are planned GitHub Release artifacts; container images remain CI smoke coverage.' },
  { icon: 'life-buoy', h: 'Support boundary', p: 'No public support window or managed service commitment exists before a reviewed release.' },
];

const selfHostLines = [
  'Local Docker Compose stack',
  'Your infrastructure, your data',
  'You run upgrades, backups, and keys',
  'Community support, today',
];
const cloudLines = [
  'No public managed service is available',
  'No region or support commitment is promised',
  'No email collection is active on this site',
  'Release gates define public readiness',
];

---

<SiteLayout
  title="Cloud"
  description="Cloud is not a public CairnID offering yet. Use the self-hosted open-source release and release-gate docs to evaluate CairnID today."
  active="cloud"
  ctaLabel="Read the docs"
  ctaHref="/docs/"
>
  <!-- HERO — staggered reveal: cloud → title → sign-up, on a blueprint grid w/ rails -->
  <section class="relative overflow-hidden pt-[clamp(72px,11vw,184px)] pb-[clamp(60px,8vw,120px)]">
    <div class="ch-bg" aria-hidden="true"></div>
    <div class="wrap relative z-[1]">
      <div class="mx-auto flex max-w-[620px] flex-col items-center text-center">
        <!-- 1 — the cloud arrives first -->
        <div class="relative mb-[clamp(40px,6vw,76px)]">
          <div class="ch-glow" aria-hidden="true"></div>
          <div class="ch-cloud cloud-mask relative z-[1] aspect-[3/2] w-[clamp(200px,26vw,320px)] [&_canvas]:block [&_canvas]:h-full! [&_canvas]:w-full!">
            <GemMark image="/shapes/cloud.svg" size={0.66} outerGlow={0.18} innerGlow={1} client:only="react" />
          </div>
        </div>

        <!-- 2 — title -->
        <h1 class="ch-title text-[clamp(20px,2.6vw,30px)] font-semibold tracking-[-0.02em] text-fg">
          Cloud. <span class="font-medium text-muted">Future work.</span>
        </h1>

        <!-- 3 - status -->
        <div class="ch-form mt-8 w-full max-w-[520px] rounded-md border border-line bg-card px-4 py-3 text-left shadow-[var(--shadow-xs)]">
          <div class="flex items-start gap-3">
            <div class="grid h-9 w-9 shrink-0 place-items-center rounded-sm border border-accent/20 bg-accent-subtle text-accent"><Icon name="info" size={17} /></div>
            <div>
              <h2 class="text-[14px] font-semibold tracking-[-0.01em] text-fg">No email collection is active here</h2>
              <p class="mt-1 text-[13px] leading-[1.5] text-secondary">Cloud is not available as a service from this site. Use the docs to evaluate the self-hosted release and its remaining public-readiness gates.</p>
              <div class="mt-3 flex flex-wrap gap-2.5">
                <a class="cn-btn cn-btn--primary cn-btn--sm" href="/docs/release-gates/">Release gates</a>
                <a class="cn-btn cn-btn--secondary cn-btn--sm" href="/docs/deployment/">Deployment docs</a>
              </div>
            </div>
          </div>
        </div>
        <div class="ch-micro mt-4 inline-flex items-center gap-[7px] text-[13px] text-muted">
          <Icon name="git-branch" size={14} class="text-accent" />Self-hosting stays free and open source - <a class="text-accent underline-offset-2 hover:underline" href="/docs/deployment/">read deployment docs</a>.
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="border-t border-line py-[clamp(52px,7vw,88px)]">
    <div class="wrap">
      <div class="mx-auto mb-[clamp(30px,4vw,48px)] max-w-[60ch] text-center">
        <div class="font-mono text-xs text-accent">current scope</div>
        <h2 class="mt-2.5 text-[clamp(25px,3.2vw,36px)] leading-[1.08] tracking-[-0.022em]">Self-hosted first,<br />with release gates in view</h2>
        <p class="mt-3.5 text-[15.5px] leading-[1.55] text-secondary">The public site currently documents self-hosting and release evidence. Any managed service would need separate evidence before it is offered.</p>
      </div>
      <div class="grid grid-cols-3 gap-3.5 max-[880px]:grid-cols-2 max-[560px]:grid-cols-1">
        {features.map((f) => (
          <div class="rounded-md border border-line bg-card p-6 transition-[border-color,transform] duration-[160ms] ease-standard hover:-translate-y-0.5 hover:border-line-strong">
            <div class="mb-[15px] grid h-[38px] w-[38px] place-items-center rounded-sm border border-accent/20 bg-accent-subtle text-accent"><Icon name={f.icon} size={18} /></div>
            <h3 class="text-base font-semibold tracking-[-0.01em]">{f.h}</h3>
            <p class="mt-2 text-[13.5px] leading-[1.55] text-secondary">{f.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPARE -->
  <section class="border-t border-line bg-sunken py-[clamp(52px,7vw,88px)]">
    <div class="wrap">
      <div class="mx-auto mb-[clamp(30px,4vw,48px)] max-w-[60ch] text-center">
        <div class="font-mono text-xs text-accent">self-hosting and future scope</div>
        <h2 class="mt-2.5 text-[clamp(25px,3.2vw,36px)] leading-[1.08] tracking-[-0.022em]">Use the open-source path today</h2>
      </div>
      <div class="mx-auto grid max-w-[880px] grid-cols-2 gap-[18px] max-[720px]:grid-cols-1">
        <div class="overflow-hidden rounded-md border border-line bg-card">
          <div class="border-b border-line-subtle px-5 py-[18px]">
            <h3 class="flex items-center gap-2 text-base"><Icon name="server" size={17} class="text-secondary" />Self-hosted</h3>
            <div class="mt-1 text-[13px] text-muted">Free · Apache-2.0 · available today</div>
          </div>
          <ul class="m-0 grid list-none gap-[11px] px-5 pb-[22px] pt-3.5">
            {selfHostLines.map((l) => (
              <li class="flex gap-2.5 text-[13.5px] leading-[1.5] text-secondary"><Icon name="check" size={16} class="mt-px shrink-0 text-accent" />{l}</li>
            ))}
          </ul>
        </div>
        <div class="overflow-hidden rounded-md border border-accent bg-card shadow-[var(--shadow-sm)]">
          <div class="border-b border-line-subtle bg-accent-subtle px-5 py-[18px]">
            <h3 class="flex items-center gap-2 text-base"><Icon name="cloud" size={17} class="text-accent" />CairnID Cloud</h3>
            <div class="mt-1 text-[13px] font-semibold text-accent">Future work - not available</div>
          </div>
          <ul class="m-0 grid list-none gap-[11px] px-5 pb-[22px] pt-3.5">
            {cloudLines.map((l) => (
              <li class="flex gap-2.5 text-[13.5px] leading-[1.5] text-secondary"><Icon name="check" size={16} class="mt-px shrink-0 text-accent" />{l}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-line py-[clamp(60px,8vw,96px)] text-center">
    <div class="wrap">
      <h2 class="text-[clamp(28px,3.6vw,40px)] tracking-[-0.025em]">Start with self-hosted evaluation</h2>
      <p class="mx-auto mt-3.5 max-w-[48ch] text-base leading-[1.55] text-secondary">Run the local Compose stack and review the release gates. The docs state what must close before CairnID can be recommended for production use.</p>
      <div class="mx-auto mt-[26px] flex w-full max-w-[440px] justify-center gap-3 max-[560px]:flex-col">
        <a class="cn-btn cn-btn--primary h-11 px-5" href="/docs/deployment/">Deployment docs</a>
        <a class="cn-btn cn-btn--secondary h-11 px-5" href="/docs/release-gates/">Release gates</a>
      </div>
    </div>
  </section>
</SiteLayout>


<style>
  /* The hero is built to feel intentional: a faded blueprint dot-grid, two
     technical tick-mark rails, and a staggered entrance — the cloud arrives
     first, then the title, then the sign-up. */

  /* blueprint grid — real squares, bigger cells, emphasised on the left & right */
  .ch-bg {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background-image:
      linear-gradient(to right, var(--border-default) 1px, transparent 1px),
      linear-gradient(to bottom, var(--border-default) 1px, transparent 1px);
    background-size: 104px 104px;
    -webkit-mask-image:
      linear-gradient(to right, #000, transparent 34%, transparent 66%, #000),
      linear-gradient(to bottom, transparent, #000 9%, #000 91%, transparent);
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(to right, #000, transparent 34%, transparent 66%, #000),
      linear-gradient(to bottom, transparent, #000 9%, #000 91%, transparent);
    mask-composite: intersect;
    opacity: 0.5;
  }
  :root[data-theme="dark"] .ch-bg { opacity: 0.7; }

  /* cloud halo */
  .ch-glow {
    position: absolute; inset: -22% -14%; z-index: 0; pointer-events: none;
    background: radial-gradient(closest-side, color-mix(in srgb, var(--accent) 22%, transparent), transparent 72%);
    filter: blur(26px);
    animation: ch-cloud-in 1.2s 0.1s var(--ease-out) both;
  }
  :root[data-theme="dark"] .ch-glow {
    background: radial-gradient(closest-side, color-mix(in srgb, var(--accent) 32%, transparent), transparent 70%);
  }

  .cloud-mask {
    -webkit-mask-image: radial-gradient(ellipse 74% 74% at 50% 48%, #000 64%, transparent 100%);
    mask-image: radial-gradient(ellipse 74% 74% at 50% 48%, #000 64%, transparent 100%);
  }

  /* staggered entrance — cloud, then title, then sign-up, then the fine print */
  .ch-cloud { animation: ch-cloud-in 1s 0.15s var(--ease-out) both; }
  .ch-title { animation: ch-up 0.7s 0.62s var(--ease-out) both; }
  .ch-form  { animation: ch-up 0.7s 0.8s var(--ease-out) both; }
  .ch-micro { animation: ch-up 0.7s 0.94s var(--ease-out) both; }

  .ch-status { margin-top: 12px; font-size: 13px; color: var(--accent); opacity: 0; transform: translateY(-2px); transition: opacity 0.25s var(--ease-out), transform 0.25s var(--ease-out); }
  .ch-status.is-shown { opacity: 1; transform: none; }

  @keyframes ch-cloud-in { from { opacity: 0; transform: scale(0.9) translateY(10px); } }
  @keyframes ch-up { from { opacity: 0; transform: translateY(16px); } }

  @media (prefers-reduced-motion: reduce) {
    .ch-glow, .ch-cloud, .ch-title, .ch-form, .ch-micro { animation: none; }
  }
</style>
