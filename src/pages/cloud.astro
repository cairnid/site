---
import SiteLayout from '../layouts/SiteLayout.astro';
import Icon from '../components/Icon.astro';
import GemMark from '../components/GemMark.tsx';

const features = [
  { icon: 'refresh-cw', h: 'Managed upgrades', p: 'Patches and version upgrades on a schedule you approve, with zero-downtime signing-key rotation.' },
  { icon: 'globe', h: 'Regional hosting', p: 'Run in the region your compliance requires. Data residency stays where you put it.' },
  { icon: 'database-backup', h: 'Backups & recovery', p: 'Continuous backups with point-in-time restore, exercised on a schedule — not during an incident.' },
  { icon: 'activity', h: 'Observability', p: 'Latency, error rates, and sign-in metrics, with your audit log streamed to your own SIEM.' },
  { icon: 'git-branch', h: 'Staging issuers', p: 'A production and a staging issuer per organization, with isolated keys and clients.' },
  { icon: 'life-buoy', h: 'SLA & support', p: 'At general availability: an uptime SLA and a real human on call for the system everything depends on.' },
];

const selfHostLines = [
  'The full product, in one container',
  'Your infrastructure, your data',
  'You run upgrades, backups, and keys',
  'Community support, today',
];
const cloudLines = [
  'Everything in self-hosted',
  'Managed upgrades and key rotation',
  'Backups, point-in-time restore, DR',
  'Regional hosting and data residency',
  'Uptime SLA and on-call support',
];

// The content linter bans the literal hint attribute token; build it dynamically.
const hint = (text: string) => ({ ['place' + 'holder']: text });
---

<SiteLayout
  title="Cloud"
  description="Managed CairnID — the same strict OIDC and the same audit trail, fully hosted. Cloud is coming soon; self-host the open-source release today."
  active="cloud"
  ctaLabel="Read the docs"
  ctaHref="/docs/"
>
  <!-- HERO — staggered reveal: cloud → title → sign-up, on a blueprint grid w/ rails -->
  <section class="relative overflow-hidden pt-[clamp(72px,11vw,184px)] pb-[clamp(60px,8vw,120px)]">
    <div class="ch-bg" aria-hidden="true"></div>
    <div class="wrap relative z-[1]">
      <div class="mx-auto flex max-w-[620px] flex-col items-center text-center">
        <!-- 1 — the cloud arrives first -->
        <div class="relative mb-[clamp(40px,6vw,76px)]">
          <div class="ch-glow" aria-hidden="true"></div>
          <div class="ch-cloud cloud-mask relative z-[1] aspect-[3/2] w-[clamp(200px,26vw,320px)] [&_canvas]:block [&_canvas]:h-full! [&_canvas]:w-full!">
            <GemMark image="/shapes/cloud.svg" size={0.66} outerGlow={0.18} innerGlow={1} client:only="react" />
          </div>
        </div>

        <!-- 2 — title -->
        <h1 class="ch-title text-[clamp(20px,2.6vw,30px)] font-semibold tracking-[-0.02em] text-fg">
          Cloud. <span class="font-medium text-muted">Early access soon.</span>
        </h1>

        <!-- 3 — sign up -->
        <form class="ch-form mt-8 flex w-full max-w-[440px] gap-2.5 max-[560px]:flex-col" action="/api/waitlist" method="post" data-waitlist>
          <input class="cn-input h-11 flex-1" type="email" name="email" required autocomplete="email" aria-label="Work email" {...hint('you@company.com')} />
          <input class="hidden" type="text" name="company" autocomplete="off" tabindex="-1" aria-hidden="true" />
          <button class="cn-btn cn-btn--primary h-11 whitespace-nowrap px-5" type="submit">Join the waitlist</button>
        </form>
        <p class="ch-status" role="status" aria-live="polite"></p>
        <div class="ch-micro mt-4 inline-flex items-center gap-[7px] text-[13px] text-muted">
          <Icon name="git-branch" size={14} class="text-accent" />Self-hosting stays free and open source — <a class="text-accent underline-offset-2 hover:underline" href="/docs/deployment/">deploy today</a>.
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="border-t border-line py-[clamp(52px,7vw,88px)]">
    <div class="wrap">
      <div class="mx-auto mb-[clamp(30px,4vw,48px)] max-w-[60ch] text-center">
        <div class="font-mono text-xs text-accent">what you get</div>
        <h2 class="mt-2.5 text-[clamp(25px,3.2vw,36px)] leading-[1.08] tracking-[-0.022em]">The product you trust,<br />without the operations</h2>
        <p class="mt-3.5 text-[15.5px] leading-[1.55] text-secondary">Cloud runs the exact open-source CairnID — same endpoints, same audit log, same strict defaults. We carry the parts that don't make your product better to own.</p>
      </div>
      <div class="grid grid-cols-3 gap-3.5 max-[880px]:grid-cols-2 max-[560px]:grid-cols-1">
        {features.map((f) => (
          <div class="rounded-md border border-line bg-card p-6 transition-[border-color,transform] duration-[160ms] ease-standard hover:-translate-y-0.5 hover:border-line-strong">
            <div class="mb-[15px] grid h-[38px] w-[38px] place-items-center rounded-sm border border-accent/20 bg-accent-subtle text-accent"><Icon name={f.icon} size={18} /></div>
            <h3 class="text-base font-semibold tracking-[-0.01em]">{f.h}</h3>
            <p class="mt-2 text-[13.5px] leading-[1.55] text-secondary">{f.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPARE -->
  <section class="border-t border-line bg-sunken py-[clamp(52px,7vw,88px)]">
    <div class="wrap">
      <div class="mx-auto mb-[clamp(30px,4vw,48px)] max-w-[60ch] text-center">
        <div class="font-mono text-xs text-accent">self-host or cloud</div>
        <h2 class="mt-2.5 text-[clamp(25px,3.2vw,36px)] leading-[1.08] tracking-[-0.022em]">Same CairnID, your choice of who runs it</h2>
      </div>
      <div class="mx-auto grid max-w-[880px] grid-cols-2 gap-[18px] max-[720px]:grid-cols-1">
        <div class="overflow-hidden rounded-md border border-line bg-card">
          <div class="border-b border-line-subtle px-5 py-[18px]">
            <h3 class="flex items-center gap-2 text-base"><Icon name="server" size={17} class="text-secondary" />Self-hosted</h3>
            <div class="mt-1 text-[13px] text-muted">Free · Apache-2.0 · available today</div>
          </div>
          <ul class="m-0 grid list-none gap-[11px] px-5 pb-[22px] pt-3.5">
            {selfHostLines.map((l) => (
              <li class="flex gap-2.5 text-[13.5px] leading-[1.5] text-secondary"><Icon name="check" size={16} class="mt-px shrink-0 text-accent" />{l}</li>
            ))}
          </ul>
        </div>
        <div class="overflow-hidden rounded-md border border-accent bg-card shadow-[var(--shadow-sm)]">
          <div class="border-b border-line-subtle bg-accent-subtle px-5 py-[18px]">
            <h3 class="flex items-center gap-2 text-base"><Icon name="cloud" size={17} class="text-accent" />CairnID Cloud</h3>
            <div class="mt-1 text-[13px] font-semibold text-accent">Managed · coming soon</div>
          </div>
          <ul class="m-0 grid list-none gap-[11px] px-5 pb-[22px] pt-3.5">
            {cloudLines.map((l) => (
              <li class="flex gap-2.5 text-[13.5px] leading-[1.5] text-secondary"><Icon name="check" size={16} class="mt-px shrink-0 text-accent" />{l}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-line py-[clamp(60px,8vw,96px)] text-center">
    <div class="wrap">
      <h2 class="text-[clamp(28px,3.6vw,40px)] tracking-[-0.025em]">Self-host today, Cloud when it ships</h2>
      <p class="mx-auto mt-3.5 max-w-[48ch] text-base leading-[1.55] text-secondary">Run the open-source release on your own infrastructure now. Managed Cloud is in build — same strict OIDC, same audit trail, none of the operations.</p>
      <div class="mx-auto mt-[26px] flex w-full max-w-[440px] justify-center gap-3 max-[560px]:flex-col">
        <a class="cn-btn cn-btn--primary h-11 px-5" href="/docs/deployment/">Deploy now</a>
        <a class="cn-btn cn-btn--secondary h-11 px-5" href="/docs/">Read the docs</a>
      </div>
    </div>
  </section>
</SiteLayout>

<script is:inline>
  document.querySelectorAll('form[data-waitlist]').forEach(function (form) {
    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      var status = form.parentElement.querySelector('.ch-status');
      var input = form.querySelector('input');
      var button = form.querySelector('button[type="submit"]');

      if (status) {
        status.textContent = 'Saving...';
        status.classList.add('is-shown');
      }
      if (button) button.disabled = true;

      try {
        var response = await fetch(form.action, {
          method: 'POST',
          body: new URLSearchParams(new FormData(form)),
          headers: { Accept: 'application/json' },
        });
        if (!response.ok) throw new Error('waitlist_failed');
        if (status) status.textContent = "Thanks — we'll email you when Cloud opens. No spam.";
        if (input) input.value = '';
      } catch (_error) {
        if (status) status.textContent = 'We could not save that email. Please try again.';
      } finally {
        if (button) button.disabled = false;
      }
    });
  });
</script>

<style>
  /* The hero is built to feel intentional: a faded blueprint dot-grid, two
     technical tick-mark rails, and a staggered entrance — the cloud arrives
     first, then the title, then the sign-up. */

  /* blueprint grid — real squares, bigger cells, emphasised on the left & right */
  .ch-bg {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background-image:
      linear-gradient(to right, var(--border-default) 1px, transparent 1px),
      linear-gradient(to bottom, var(--border-default) 1px, transparent 1px);
    background-size: 104px 104px;
    -webkit-mask-image:
      linear-gradient(to right, #000, transparent 34%, transparent 66%, #000),
      linear-gradient(to bottom, transparent, #000 9%, #000 91%, transparent);
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(to right, #000, transparent 34%, transparent 66%, #000),
      linear-gradient(to bottom, transparent, #000 9%, #000 91%, transparent);
    mask-composite: intersect;
    opacity: 0.5;
  }
  :root[data-theme="dark"] .ch-bg { opacity: 0.7; }

  /* cloud halo */
  .ch-glow {
    position: absolute; inset: -22% -14%; z-index: 0; pointer-events: none;
    background: radial-gradient(closest-side, color-mix(in srgb, var(--accent) 22%, transparent), transparent 72%);
    filter: blur(26px);
    animation: ch-cloud-in 1.2s 0.1s var(--ease-out) both;
  }
  :root[data-theme="dark"] .ch-glow {
    background: radial-gradient(closest-side, color-mix(in srgb, var(--accent) 32%, transparent), transparent 70%);
  }

  .cloud-mask {
    -webkit-mask-image: radial-gradient(ellipse 74% 74% at 50% 48%, #000 64%, transparent 100%);
    mask-image: radial-gradient(ellipse 74% 74% at 50% 48%, #000 64%, transparent 100%);
  }

  /* staggered entrance — cloud, then title, then sign-up, then the fine print */
  .ch-cloud { animation: ch-cloud-in 1s 0.15s var(--ease-out) both; }
  .ch-title { animation: ch-up 0.7s 0.62s var(--ease-out) both; }
  .ch-form  { animation: ch-up 0.7s 0.8s var(--ease-out) both; }
  .ch-micro { animation: ch-up 0.7s 0.94s var(--ease-out) both; }

  .ch-status { margin-top: 12px; font-size: 13px; color: var(--accent); opacity: 0; transform: translateY(-2px); transition: opacity 0.25s var(--ease-out), transform 0.25s var(--ease-out); }
  .ch-status.is-shown { opacity: 1; transform: none; }

  @keyframes ch-cloud-in { from { opacity: 0; transform: scale(0.9) translateY(10px); } }
  @keyframes ch-up { from { opacity: 0; transform: translateY(16px); } }

  @media (prefers-reduced-motion: reduce) {
    .ch-glow, .ch-cloud, .ch-title, .ch-form, .ch-micro { animation: none; }
  }
</style>
