          <div class="text-[12.5px] font-semibold tracking-normal text-accent">Quick start</div>
          <h2 class="mt-2 max-w-[22ch] text-[clamp(25px,3vw,34px)] leading-[1.08] tracking-[-0.018em]">Run the local stack with Docker Compose</h2>
          <p class="mt-3 max-w-[56ch] text-[15px] leading-[1.55] text-secondary">Generate a key-encryption key, set it, and run the full local stack with Docker Compose. Bootstrap the first administrator from <code style="font-family:var(--font-mono);font-size:0.9em;">/login</code>.</p>
        </div>
      </div>
      <div class="overflow-hidden rounded-md border border-line bg-card">
        <div class="flex items-center gap-[7px] border-b border-line-subtle bg-sunken px-3.5 py-2.5">
          <span class="flex gap-[5px]"><i class="h-2 w-2 rounded-full bg-line-strong"></i><i class="h-2 w-2 rounded-full bg-line-strong"></i><i class="h-2 w-2 rounded-full bg-line-strong"></i></span>
          <span class="font-mono text-[11.5px] text-muted">bash</span>
        </div>
        <div class="term-body overflow-x-auto whitespace-pre px-[18px] py-[15px] font-mono text-[12.5px] leading-[1.85] text-secondary" set:html={quickstartTerminal}></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="border-y border-line bg-sunken">
    <section class="py-[clamp(56px,7vw,92px)] text-center">
      <div class="wrap">
        <h2 class="text-[clamp(26px,3.4vw,38px)] leading-[1.08] tracking-[-0.02em]">Run it locally with Compose</h2>
        <p class="mx-auto mt-3.5 max-w-[50ch] text-base leading-[1.55] text-secondary">Generate a key, start the local stack, and bootstrap the first admin. No account to create and no sales call  -  it's open source, all the way down.</p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a class="cn-btn cn-btn--primary" href="#start"><Icon name="terminal" size={16} />Get started</a>
          <a class="cn-btn cn-btn--secondary" href="https://github.com/cairnid/cairnid"><Icon name="github" size={16} />View on GitHub</a>
        </div>
      </div>
    </section>
  </div>
</SiteLayout>

<script is:inline>
  (function () {
    var order = ['overview', 'applications', 'users', 'groups', 'audit', 'settings'];
    var navs = [].slice.call(document.querySelectorAll('.cs-side [data-screen]'));
    var screens = [].slice.call(document.querySelectorAll('.cs-screen'));
    var shot = document.querySelector('.hero-shot');
    var i = 0, paused = false;
    if (shot) { shot.addEventListener('mouseenter', function () { paused = true; }); shot.addEventListener('mouseleave', function () { paused = false; }); }
    function show(id) {
      screens.forEach(function (s) { s.classList.toggle('is-on', s.getAttribute('data-screen') === id); });
      navs.forEach(function (n) { n.classList.toggle('is-active', n.getAttribute('data-screen') === id); });
    }
    show('overview');
    setInterval(function () { if (paused) { return; } i = (i + 1) % order.length; show(order[i]); }, 2600);
  })();
</script>
<script is:inline>
  (function () {
    var flow = document.getElementById('pflow');
    if (!flow) { return; }
    var tabs = [].slice.call(flow.querySelectorAll('.ptab'));
    var frames = [].slice.call(flow.querySelectorAll('.pframe'));
    var i = 0, paused = false, timer;
    function show(n) {
      i = n;
      tabs.forEach(function (t, k) { t.classList.toggle('on', k === n); });
      frames.forEach(function (f, k) { f.classList.toggle('on', k === n); });
    }
    function restart() { clearInterval(timer); timer = setInterval(function () { if (!paused) { show((i + 1) % tabs.length); } }, 3800); }
    tabs.forEach(function (t, k) { t.addEventListener('click', function () { show(k); restart(); }); });
    flow.addEventListener('mouseenter', function () { paused = true; });
    flow.addEventListener('mouseleave', function () { paused = false; });
    show(0); restart();
  })();
</script>


<style>
  /* Only what utilities express poorly: keyframes/animations, set:html span
     coloring, pseudo-element switches, JS-toggled multi-state selectors, and
     descendant overrides of component (cn-*) table cells. */

  /* Hero typewriter cursor */
  @media (prefers-reduced-motion: no-preference) { .cursor { animation: blink 1.1s steps(1, end) infinite; } }
  @keyframes blink { 50% { opacity: 0; } }

  /* Console table cells (cn-table descendants, set via td class) */
  .cs-main .va { font-family: var(--font-mono); font-size: 12px; color: var(--text-primary); white-space: nowrap; }
  .cs-main .vu { font-size: 12px; color: var(--text-secondary); white-space: nowrap; }
  .cs-main .vt { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); white-space: nowrap; }
  .cs-main .nm { font-weight: 500; font-size: 13px; white-space: nowrap; }
  .cs-main .cn-table td { padding-top: 8px; padding-bottom: 8px; }
  .cs-cid .cn-copyfield { padding: 3px 4px 3px 8px; max-width: 168px; }
  .cs-cid .cn-copyfield__value { font-size: 12px; }

  /* Mini toggle switch (pseudo-element knob) */
  .mini-switch { width: 30px; height: 18px; border-radius: 999px; background: var(--border-strong); position: relative; flex: none; }
  .mini-switch::after { content: ""; position: absolute; top: 2px; left: 2px; width: 14px; height: 14px; border-radius: 50%; background: #fff; transition: left .2s var(--ease-standard); }
  .mini-switch.is-on { background: var(--accent); }
  .mini-switch.is-on::after { left: 14px; }

  /* Bento table cells (cn-table descendants, set via td class) */
  .b .cn-table td { padding: 8px 12px; }
  .b .va { font-family: var(--font-mono); font-size: 12px; color: var(--text-primary); white-space: nowrap; }
  .b .vu { font-size: 12px; color: var(--text-secondary); white-space: nowrap; }
  .b .vt { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); text-align: right; white-space: nowrap; }

  /* "Left out" strike-through underline animation */
  .nope-row .nm::after { content: ""; position: absolute; left: 0; top: 52%; height: 1.5px; width: 0; background: var(--danger-fg); transition: width 240ms var(--ease-out); }
  .nope-row:hover .nm::after, .nope-row:focus-within .nm::after { width: 100%; }
  @media (prefers-reduced-motion: reduce) { .nope-row .nm::after { transition: none; } }

  /* Terminal / code span coloring (rendered via set:html) */
  .term-body .pr { color: var(--accent); user-select: none; }
  .term-body .cm { color: var(--text-muted); }
  .term-body .fl { color: var(--caution-fg); }
  .term-body .st { color: var(--text-primary); }
  .pcode-body .cm { color: var(--text-muted); }
  .pcode-body .k { color: var(--accent); }
  .pcode-body .s { color: var(--text-primary); }
  .pcode-body .ok { color: var(--success-fg); }
  .pcode-body .fl { color: var(--caution-fg); }

  /* Protocol stepper tabs  -  JS-toggled .on + hover compound states */
  .ptab { flex: 1; min-width: max-content; display: flex; align-items: center; justify-content: center; gap: 9px; padding: 14px 18px; margin-bottom: -1px; font: inherit; font-size: 13.5px; font-weight: 500; color: var(--text-muted); background: none; border: 0; border-bottom: 2px solid transparent; cursor: pointer; white-space: nowrap; transition: color 140ms var(--ease-standard), background 140ms var(--ease-standard), border-color 140ms var(--ease-standard); }
  .ptab:hover:not(.on) { color: var(--text-primary); background: var(--surface-hover); }
  .ptab:hover:not(.on) .tn { border-color: var(--accent); color: var(--accent); }
  .ptab.on { color: var(--text-primary); font-weight: 600; border-bottom-color: var(--accent); background: var(--surface-card); }
  .ptab .tn { width: 23px; height: 23px; border-radius: 50%; border: 1px solid var(--border-strong); display: grid; place-items: center; font-family: var(--font-mono); font-size: 11px; font-weight: 600; color: var(--text-muted); transition: background 140ms var(--ease-standard), color 140ms var(--ease-standard), border-color 140ms var(--ease-standard), box-shadow 140ms var(--ease-standard); }
  .ptab.on .tn { background: var(--accent-bg); border-color: var(--accent-bg); color: var(--text-on-accent); box-shadow: 0 0 0 3px var(--accent-subtle); }
  @media (max-width: 720px) { .ptab { flex: none; } }
  .pframe { display: none; }
  .pframe.on { display: block; }
  .vb { font-size: 10px; font-weight: 700; letter-spacing: 0.05em; padding: 3px 7px; border-radius: var(--radius-xs); }
  .vb.get { color: var(--accent); background: var(--accent-subtle); }
  .vb.post { color: var(--caution-fg); background: var(--caution-bg); }
</style>
