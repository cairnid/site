                  <h3 class="text-[19px] font-semibold tracking-[-0.015em]">{step.h}</h3>
                  <p class="mt-[11px] text-sm leading-[1.6] text-secondary">{step.d}</p>
                  <div class="mt-auto pt-5 font-mono text-[11.5px] text-muted">{step.meta}</div>
                </div>
                <div class="overflow-x-auto bg-[var(--code-bg)]"><div class="pcode-body min-h-[268px] whitespace-pre px-[26px] py-6 font-mono text-[12.5px] leading-[1.95] text-secondary" set:html={protoFrames[i]}></div></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>

  <!-- QUICK START -->
  <section class="py-[clamp(56px,7vw,92px)]" id="start">
    <div class="wrap">
      <div class="mb-10 grid grid-cols-[auto_1fr] items-start gap-4">
        <div class="pt-1 font-mono text-xs font-medium text-accent">05</div>
