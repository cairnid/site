              <button type="button" class={`ptab${i === 0 ? ' on' : ''}`} data-i={i}><span class="tn">{i + 1}</span><span class="tlabel max-[720px]:hidden">{label}</span></button>
            ))}
          </div>
          {protoSteps.map((step, i) => (
            <div class={`pframe${i === 0 ? ' on' : ''}`} data-i={i}>
              <div class="grid [grid-template-columns:0.76fr_1.24fr] max-[720px]:grid-cols-1">
