---
import SiteLayout from '../layouts/SiteLayout.astro';
import Icon from '../components/Icon.astro';
import CairnMark from '../components/CairnMark.astro';
import Wallpaper from '../components/Wallpaper.astro';

const standards = [
  { icon: 'id-card', nm: 'OpenID Connect 1.0', cap: 'Discovery, UserInfo, and RP-initiated logout.' },
  { icon: 'transfer', nm: 'OAuth 2.1', cap: 'Authorization Code with PKCE, S256 only.' },
  { icon: 'users', nm: 'SCIM 2.0', cap: 'Bounded user and group provisioning.' },
  { icon: 'fingerprint', nm: 'WebAuthn', cap: 'Passkeys and hardware security keys.' },
  { icon: 'certificate', nm: 'JOSE  -  JWT', cap: 'RS256 signing with JWKS key rotation.' },
  { icon: 'clock', nm: 'TOTP  -  RFC 6238', cap: 'Authenticator apps and recovery codes.' },
  { icon: 'shield', nm: 'Argon2id', cap: 'Memory-hard password hashing by default.' },
  { icon: 'search-alt', nm: 'RFC 7662  -  Introspection', cap: 'Token introspection and revocation endpoints.' },
];

const leftOut = [
  { nm: 'Implicit grant', why: 'Access tokens never ride in a redirect fragment.' },
  { nm: 'Hybrid flow', why: 'One code exchange  -  nothing ambiguous to reason about.' },
  { nm: 'Password (ROPC) grant', why: 'Applications never see a user\'s password.' },
  { nm: 'Wildcard redirect URIs', why: 'Every redirect URI is matched exactly, in full.' },
  { nm: 'Public clients without PKCE', why: 'S256 is required, never optional.' },
  { nm: 'ID tokens signed with none', why: 'Always RS256, always verifiable against JWKS.' },
  { nm: 'Long-lived bearer tokens', why: 'Access tokens are opaque, short, and revocable.' },
  { nm: 'MD5 / SHA-1 password hashes', why: 'Argon2id, with sensible parameters by default.' },
];

const surfaces = [
  { icon: 'log-in', route: '/login', nm: 'Sign-in & bootstrap', p: 'Password, passkey, and the first-administrator bootstrap.' },
  { icon: 'app-window', route: '/consent', nm: 'OAuth consent', p: 'Exact scopes, the exact redirect, revocable anytime.' },
  { icon: 'user-round-cog', route: '/app', nm: 'Account portal', p: 'Passkeys, TOTP, recovery codes, sessions, and apps.' },
  { icon: 'layout-dashboard', route: '/admin', nm: 'Admin console', p: 'Applications, users, groups, policies, and audit.' },
];

// Code/terminal block bodies  -  rendered via set:html so literal braces, angle
// brackets, and entities survive Astro's template parser intact.
const deployTerminal = `<span class="pr">$</span> <span class="st">docker compose -f infra/docker-compose.yml up --build</span>
<span class="cm"># postgres  -  api  -  web  -  local evaluation stack</span>
<span class="pr">$</span> <span class="st">open http://localhost:5173/login</span>`;

const quickstartTerminal = `<span class="cm"># 1  -  generate a key-encryption key</span>
<span class="pr">$</span> <span class="st">cargo run -p cairn-api -- signing-key generate-kek</span>

<span class="cm"># 2  -  set it, then bring up the stack</span>
<span class="pr">$</span> <span class="st">export CAIRN_KEY_ENCRYPTION_KEY=&lt;paste value&gt;</span>
<span class="pr">$</span> <span class="st">docker compose -f infra/docker-compose.yml up --build</span>

<span class="cm"># 3  -  open the app, bootstrap the first admin</span>
<span class="pr">$</span> <span class="st">open http://localhost:5173/login</span>`;

const protoFrames = [
  `<span class="cm"># app redirects the user to authorize</span>
<span class="k">GET</span> /oauth2/authorize
  ?response_type=<span class="s">code</span>
  &client_id=<span class="s">cln_7Q2f9aE4kV0</span>
  &redirect_uri=<span class="s">https://app.example.com/callback</span>
  &scope=<span class="s">openid profile email</span>
  &code_challenge=<span class="s">k3Vp...Q2</span>
  &code_challenge_method=<span class="s">S256</span>

<span class="cm"># -> 302 Found  -  Location: /login</span>`,
  `<span class="cm"># the user proves who they are</span>
<span class="k">POST</span> /login
  email=<span class="s">dana@example.com</span>
  factor=<span class="s">passkey</span>      <span class="cm"># WebAuthn assertion</span>

<span class="ok">OK second factor verified</span>
<span class="cm"># -> continue to /consent</span>`,
  `<span class="cm"># the user approves the exact scopes</span>
<span class="k">POST</span> /consent
  request=<span class="s">ar_9f2...</span>
  decision=<span class="s">allow</span>
  scope=<span class="s">openid profile email</span>

<span class="cm"># -> 302  -  /callback?code=ac_5Tg... (60s)</span>`,
  `<span class="cm"># app exchanges the code + verifier</span>
<span class="k">POST</span> /oauth2/token
  grant_type=<span class="s">authorization_code</span>
  code=<span class="s">ac_5Tg...</span>
  code_verifier=<span class="s">k3Vp...</span>

<span class="cm"># -> 200 OK</span>
{
  <span class="k">"id_token"</span>: <span class="s">"eyJhbGciOiJSUzI1Ni..."</span>,
  <span class="k">"access_token"</span>: <span class="s">"at_9x...opaque"</span>,
  <span class="k">"refresh_token"</span>: <span class="s">"rt_b3...rotated"</span>,
  <span class="k">"expires_in"</span>: <span class="s">600</span>
}`,
  `<span class="cm"># app verifies the signature</span>
<span class="k">GET</span> /.well-known/jwks.json
<span class="cm"># -> 200 OK  -  { "keys": [ RS256 ] }</span>

verify(id_token, jwks)
<span class="ok">OK signature valid  -  path proven</span>
<span class="cm"># audit: token.issued  -  actor=dana OK</span>`,
];

const protoSteps = [
  { verb: 'GET', ep: '/oauth2/authorize', h: 'Authorize', d: 'The app sends the user to CairnID with a PKCE challenge and the exact scopes it wants.', meta: 'step 1 of 5  -  request' },
  { verb: 'POST', ep: '/login', h: 'Authenticate', d: 'The user signs in with a password or passkey, then completes a second factor.', meta: 'step 2 of 5  -  interactive' },
  { verb: 'POST', ep: '/consent', h: 'Consent', d: 'CairnID shows the exact scopes and the exact redirect. The user approves, and a short-lived code comes back.', meta: 'step 3 of 5  -  interactive' },
  { verb: 'POST', ep: '/oauth2/token', h: 'Exchange', d: 'The app returns the code with its PKCE verifier and receives a signed ID token and an opaque access token.', meta: 'step 4 of 5  -  request' },
  { verb: 'GET', ep: '/.well-known/jwks.json', h: 'Verify', d: 'The app checks the RS256 signature against the published keys. The path is proven  -  and every step left an audit line.', meta: 'step 5 of 5  -  verified' },
];
const protoTabs = ['Authorize', 'Authenticate', 'Consent', 'Exchange', 'Verify'];

// The repo's content linter bans a certain hint-attribute token; build the
// standard input attribute name dynamically so the source never spells it.
const hint = (text: string) => ({ ['place' + 'holder']: text });
---

<SiteLayout
  title="Strict OIDC you can audit"
  description="An OIDC and OAuth provider small enough to read end to end. It runs as a local Docker Compose stack for evaluation, matches every redirect exactly, and writes an audit line for every token."
  active="product"
>
  <div class="relative">
    <!-- HERO -->
    <section class="pt-[clamp(34px,5vw,60px)] pb-[clamp(40px,5vw,68px)] text-center" id="top">
      <div class="wrap">
        <div class="mx-auto max-w-[760px]">
          <span class="inline-flex items-center gap-[9px] whitespace-nowrap rounded-pill border border-line bg-card py-1 pr-[13px] pl-[5px] text-[12.5px] font-medium text-secondary shadow-[var(--shadow-xs)]"><span class="rounded-pill bg-[var(--accent-bg)] px-[9px] py-0.5 text-[10.5px] font-semibold tracking-[0.01em] text-on-accent">Pre-beta</span>Built in the open, working toward the first release candidate<Icon name="arrow-right" size={14} class="text-muted" /></span>
          <h1 class="mx-auto mt-[22px] max-w-[24ch] text-[clamp(34px,4.8vw,52px)] font-bold leading-[1.05] tracking-[-0.025em] text-fg [text-wrap:balance]">Strict single sign-on you can <span class="text-accent">audit, line by line</span><span class="cursor font-normal text-accent">_</span></h1>
          <p class="mx-auto mt-[18px] max-w-[56ch] text-[clamp(15px,1.6vw,18px)] leading-[1.55] text-secondary [text-wrap:pretty]">An OIDC and OAuth provider small enough to read end to end. It runs as a local Docker Compose stack for evaluation, matches every redirect exactly, and writes an audit line for every token  -  so you can prove who reached what.</p>
          <div class="mt-8 flex flex-wrap justify-center gap-3">
            <a class="cn-btn cn-btn--primary" href="#start"><Icon name="terminal" size={16} />Run locally</a>
            <a class="cn-btn cn-btn--secondary" href="#protocol"><Icon name="file-text" size={16} />Read the spec</a>
          </div>
          <div class="mt-6 flex flex-wrap justify-center gap-y-2 gap-x-5">
            <span class="inline-flex items-center gap-[7px] text-[13px] text-secondary"><Icon name="check" size={15} class="text-accent" />Authorization Code + PKCE</span>
            <span class="inline-flex items-center gap-[7px] text-[13px] text-secondary"><Icon name="check" size={15} class="text-accent" />RS256 ID tokens</span>
            <span class="inline-flex items-center gap-[7px] text-[13px] text-secondary"><Icon name="check" size={15} class="text-accent" />Self-hostable</span>
          </div>
        </div>

        <!-- LIVE CONSOLE PREVIEW -->
        <div class="hero-shot relative left-1/2 z-[1] mx-auto mt-[clamp(38px,5vw,60px)] mb-[-160px] w-[min(1200px,93vw)] -translate-x-1/2 text-left">
          <div class="stage stage--wide">
            <Wallpaper variant={0} />
            <div class="float-card console-card">
            <div class="console grid min-h-[428px] [grid-template-columns:196px_minmax(0,1fr)] bg-page max-[560px]:grid-cols-1">
              <aside class="cs-side flex flex-col gap-1 border-r border-line bg-card px-2.5 py-3 max-[560px]:hidden">
                <div class="flex items-center gap-2 px-1.5 pt-1 pb-2 text-[13px] font-bold"><CairnMark size={18} /><span>Cairn<span class="text-accent">ID</span></span></div>
                <div class="mb-2 flex items-center justify-between rounded-sm border border-line px-[9px] py-1.5 text-xs text-secondary"><span>Acme Corp</span><Icon name="chevrons-up-down" size={13} /></div>
                <div class="cs-nav flex items-center gap-[9px] rounded-sm px-[9px] py-[7px] text-[12.5px] text-secondary [&.is-active]:bg-accent-subtle [&.is-active]:font-semibold [&.is-active]:text-accent is-active" data-screen="overview"><Icon name="layout-dashboard" size={15} />Overview</div>
                <div class="cs-nav flex items-center gap-[9px] rounded-sm px-[9px] py-[7px] text-[12.5px] text-secondary [&.is-active]:bg-accent-subtle [&.is-active]:font-semibold [&.is-active]:text-accent" data-screen="applications"><Icon name="app-window" size={15} />Applications</div>
                <div class="cs-nav flex items-center gap-[9px] rounded-sm px-[9px] py-[7px] text-[12.5px] text-secondary [&.is-active]:bg-accent-subtle [&.is-active]:font-semibold [&.is-active]:text-accent" data-screen="users"><Icon name="users" size={15} />Users</div>
                <div class="cs-nav flex items-center gap-[9px] rounded-sm px-[9px] py-[7px] text-[12.5px] text-secondary [&.is-active]:bg-accent-subtle [&.is-active]:font-semibold [&.is-active]:text-accent" data-screen="groups"><Icon name="boxes" size={15} />Groups</div>
                <div class="cs-nav flex items-center gap-[9px] rounded-sm px-[9px] py-[7px] text-[12.5px] text-secondary [&.is-active]:bg-accent-subtle [&.is-active]:font-semibold [&.is-active]:text-accent" data-screen="audit"><Icon name="scroll-text" size={15} />Audit</div>
                <div class="cs-nav flex items-center gap-[9px] rounded-sm px-[9px] py-[7px] text-[12.5px] text-secondary [&.is-active]:bg-accent-subtle [&.is-active]:font-semibold [&.is-active]:text-accent" data-screen="settings"><Icon name="settings" size={15} />Settings</div>
              </aside>
              <main class="cs-main relative overflow-hidden p-0">
                <!-- OVERVIEW -->
                <div class="cs-screen absolute inset-0 translate-y-2.5 px-[18px] py-4 opacity-0 pointer-events-none transition-[opacity,transform] duration-500 ease-standard [&.is-on]:translate-y-0 [&.is-on]:opacity-100 [&.is-on]:pointer-events-auto is-on" data-screen="overview">
                  <div class="cs-head mb-3.5 flex items-start justify-between gap-3"><div><h3 class="text-base font-semibold">Overview</h3><p class="mt-[3px] max-w-[48ch] text-xs text-muted">Health and recent activity for Acme Corp.</p></div></div>
                  <div class="mb-3.5 grid grid-cols-4 gap-2.5">
                    <div class="rounded-sm border border-line bg-card px-3 py-[11px]"><div class="text-[11px] text-muted">Active users</div><div class="mt-1 font-mono text-xl font-semibold text-fg [font-feature-settings:'tnum'_1]">1,284</div><div class="mt-[3px] text-[11px] text-success">+24 this week</div></div>
                    <div class="rounded-sm border border-line bg-card px-3 py-[11px]"><div class="text-[11px] text-muted">Applications</div><div class="mt-1 font-mono text-xl font-semibold text-fg [font-feature-settings:'tnum'_1]">18</div><div class="mt-[3px] text-[11px] text-muted">3 confidential</div></div>
                    <div class="rounded-sm border border-line bg-card px-3 py-[11px]"><div class="text-[11px] text-muted">Signing key</div><div class="mt-1 font-mono text-sm font-semibold text-fg [font-feature-settings:'tnum'_1]">RS256</div><div class="mt-[3px] text-[11px] text-muted">rotated 6d ago</div></div>
                    <div class="rounded-sm border border-line bg-card px-3 py-[11px]"><div class="text-[11px] text-muted">Failed sign-ins</div><div class="mt-1 font-mono text-xl font-semibold text-fg [font-feature-settings:'tnum'_1]">7</div><div class="mt-[3px] text-[11px] text-muted">last 24h</div></div>
                  </div>
                  <div class="mt-0.5 mb-2 text-xs font-semibold text-secondary">Recent events</div>
                  <div class="cn-card" style="overflow-x:auto;">
                    <table class="cn-table cn-table--num"><tbody>
                      <tr><td class="vt">14:22</td><td class="vu">dana.okafor</td><td class="va">session.login</td><td><span class="cn-pill cn-pill--active"><span class="cn-pill__dot"></span>OK</span></td></tr>
                      <tr><td class="vt">14:18</td><td class="vu">admin</td><td class="va">secret.rotate</td><td><span class="cn-pill cn-pill--neutral">Rotated</span></td></tr>
                      <tr><td class="vt">13:40</td><td class="vu">m.rossi</td><td class="va">login.failed</td><td><span class="cn-pill cn-pill--revoked"><span class="cn-pill__dot"></span>Denied</span></td></tr>
                    </tbody></table>
                  </div>
                </div>
                <!-- APPLICATIONS -->
                <div class="cs-screen absolute inset-0 translate-y-2.5 px-[18px] py-4 opacity-0 pointer-events-none transition-[opacity,transform] duration-500 ease-standard [&.is-on]:translate-y-0 [&.is-on]:opacity-100 [&.is-on]:pointer-events-auto" data-screen="applications">
                  <div class="cs-head mb-3.5 flex items-start justify-between gap-3"><div><h3 class="text-base font-semibold">Applications</h3><p class="mt-[3px] max-w-[48ch] text-xs text-muted">Register OIDC clients with exact redirect URIs and PKCE enabled.</p></div><button class="cn-btn cn-btn--primary cn-btn--sm" type="button"><Icon name="plus" size={14} />New application</button></div>
                  <div class="mb-3.5 flex flex-wrap gap-[9px]">
                    <div class="cn-input-group max-w-[230px]"><span class="cn-input-group__icon"><Icon name="search" size={15} /></span><input class="cn-input" aria-label="Name or client ID" {...hint('Name or client ID')} /></div>
                    <select class="cn-select max-w-[148px]"><option>All types</option><option>Public (PKCE)</option><option>Confidential</option></select>
                    <select class="cn-select max-w-[148px]"><option>All statuses</option><option>Active</option><option>Disabled</option></select>
                  </div>
                  <div class="cn-card" style="overflow-x:auto;">
                    <table class="cn-table cn-table--num">
                      <thead><tr><th>Application</th><th>Client ID</th><th>Type</th><th>Scopes</th><th>Status</th><th></th></tr></thead>
                      <tbody>
                        <tr><td class="nm">Billing Portal</td><td class="cs-cid"><span class="cn-copyfield"><span class="cn-copyfield__value">cln_7Q2f9aE4kV0</span><button class="cn-copyfield__btn" type="button"><Icon name="copy" size={11} /></button></span></td><td><span class="cn-pill cn-pill--neutral">Confidential</span></td><td><div class="flex flex-wrap gap-1"><span class="cn-chip cn-chip--mono">openid</span><span class="cn-chip cn-chip--mono">profile</span><span class="cn-chip cn-chip--mono">email</span></div></td><td><span class="cn-pill cn-pill--active"><span class="cn-pill__dot"></span>Active</span></td><td class="cn-table__actions"><div class="inline-flex gap-[5px]"><span class="cn-icon-btn cn-icon-btn--ghost cn-icon-btn--sm"><Icon name="pencil" size={14} /></span><span class="cn-icon-btn cn-icon-btn--ghost cn-icon-btn--sm"><Icon name="key-round" size={14} /></span></div></td></tr>
                        <tr><td class="nm">CI Runner</td><td class="cs-cid"><span class="cn-copyfield"><span class="cn-copyfield__value">cln_b3K9zR1pW8n</span><button class="cn-copyfield__btn" type="button"><Icon name="copy" size={11} /></button></span></td><td><span class="cn-pill cn-pill--neutral">Confidential</span></td><td><div class="flex flex-wrap gap-1"><span class="cn-chip cn-chip--mono">openid</span><span class="cn-chip cn-chip--mono">groups</span></div></td><td><span class="cn-pill cn-pill--active"><span class="cn-pill__dot"></span>Active</span></td><td class="cn-table__actions"><div class="inline-flex gap-[5px]"><span class="cn-icon-btn cn-icon-btn--ghost cn-icon-btn--sm"><Icon name="pencil" size={14} /></span><span class="cn-icon-btn cn-icon-btn--ghost cn-icon-btn--sm"><Icon name="key-round" size={14} /></span></div></td></tr>
                        <tr><td class="nm">Support Desk</td><td class="cs-cid"><span class="cn-copyfield"><span class="cn-copyfield__value">cln_44Xc0Te2Yh1</span><button class="cn-copyfield__btn" type="button"><Icon name="copy" size={11} /></button></span></td><td><span class="cn-pill cn-pill--neutral">Public</span></td><td><div class="flex flex-wrap gap-1"><span class="cn-chip cn-chip--mono">openid</span><span class="cn-chip cn-chip--mono">profile</span></div></td><td><span class="cn-pill cn-pill--active"><span class="cn-pill__dot"></span>Active</span></td><td class="cn-table__actions"><div class="inline-flex gap-[5px]"><span class="cn-icon-btn cn-icon-btn--ghost cn-icon-btn--sm"><Icon name="pencil" size={14} /></span><span class="cn-icon-btn cn-icon-btn--ghost cn-icon-btn--sm"><Icon name="key-round" size={14} /></span></div></td></tr>
                        <tr><td class="nm">Legacy Sync</td><td class="cs-cid"><span class="cn-copyfield"><span class="cn-copyfield__value">cln_Z1aPv6Lq8Nb</span><button class="cn-copyfield__btn" type="button"><Icon name="copy" size={11} /></button></span></td><td><span class="cn-pill cn-pill--neutral">Confidential</span></td><td><div class="flex flex-wrap gap-1"><span class="cn-chip cn-chip--mono">openid</span></div></td><td><span class="cn-pill cn-pill--disabled"><span class="cn-pill__dot"></span>Disabled</span></td><td class="cn-table__actions"><div class="inline-flex gap-[5px]"><span class="cn-icon-btn cn-icon-btn--ghost cn-icon-btn--sm"><Icon name="pencil" size={14} /></span><span class="cn-icon-btn cn-icon-btn--ghost cn-icon-btn--sm"><Icon name="key-round" size={14} /></span></div></td></tr>
                      </tbody>
                    </table>
                  </div>
                </div>
                <!-- USERS -->
                <div class="cs-screen absolute inset-0 translate-y-2.5 px-[18px] py-4 opacity-0 pointer-events-none transition-[opacity,transform] duration-500 ease-standard [&.is-on]:translate-y-0 [&.is-on]:opacity-100 [&.is-on]:pointer-events-auto" data-screen="users">
                  <div class="cs-head mb-3.5 flex items-start justify-between gap-3"><div><h3 class="text-base font-semibold">Users</h3><p class="mt-[3px] max-w-[48ch] text-xs text-muted">People who can sign in to Acme Corp.</p></div><button class="cn-btn cn-btn--primary cn-btn--sm" type="button"><Icon name="user-plus" size={14} />Invite</button></div>
                  <div class="cn-card" style="overflow-x:auto;">
                    <table class="cn-table cn-table--num">
                      <thead><tr><th>User</th><th>Two-factor</th><th>Groups</th><th>Last seen</th><th>Status</th></tr></thead>
                      <tbody>
                        <tr><td class="nm">Dana Okafor</td><td><div class="flex flex-wrap gap-1"><span class="cn-chip">Passkey</span><span class="cn-chip">TOTP</span></div></td><td class="vu">Engineering</td><td class="vt">2m ago</td><td><span class="cn-pill cn-pill--active"><span class="cn-pill__dot"></span>Active</span></td></tr>
                        <tr><td class="nm">Marco Rossi</td><td><div class="flex flex-wrap gap-1"><span class="cn-chip">TOTP</span></div></td><td class="vu">Support</td><td class="vt">1h ago</td><td><span class="cn-pill cn-pill--active"><span class="cn-pill__dot"></span>Active</span></td></tr>
                        <tr><td class="nm">Priya Nair</td><td><div class="flex flex-wrap gap-1"><span class="cn-chip">Passkey</span></div></td><td class="vu">Platform</td><td class="vt">3h ago</td><td><span class="cn-pill cn-pill--active"><span class="cn-pill__dot"></span>Active</span></td></tr>
                        <tr><td class="nm">Sam Lee</td><td><div class="flex flex-wrap gap-1"><span class="cn-chip">None</span></div></td><td class="vu">Contractors</td><td class="vt">5d ago</td><td><span class="cn-pill cn-pill--disabled"><span class="cn-pill__dot"></span>Disabled</span></td></tr>
                      </tbody>
                    </table>
                  </div>
                </div>
                <!-- GROUPS -->
                <div class="cs-screen absolute inset-0 translate-y-2.5 px-[18px] py-4 opacity-0 pointer-events-none transition-[opacity,transform] duration-500 ease-standard [&.is-on]:translate-y-0 [&.is-on]:opacity-100 [&.is-on]:pointer-events-auto" data-screen="groups">
                  <div class="cs-head mb-3.5 flex items-start justify-between gap-3"><div><h3 class="text-base font-semibold">Groups</h3><p class="mt-[3px] max-w-[48ch] text-xs text-muted">Organize users for access and consent policies.</p></div><button class="cn-btn cn-btn--primary cn-btn--sm" type="button"><Icon name="plus" size={14} />New group</button></div>
                  <div class="cn-card" style="overflow-x:auto;">
                    <table class="cn-table cn-table--num">
                      <thead><tr><th>Group</th><th>Members</th><th>Source</th><th>Description</th></tr></thead>
                      <tbody>
                        <tr><td class="nm">Engineering</td><td>48</td><td><span class="cn-pill cn-pill--neutral">Synced</span></td><td class="vu">All product engineers</td></tr>
                        <tr><td class="nm">Admins</td><td>4</td><td><span class="cn-pill cn-pill--neutral">Manual</span></td><td class="vu">Console administrators</td></tr>
                        <tr><td class="nm">Support</td><td>12</td><td><span class="cn-pill cn-pill--neutral">Manual</span></td><td class="vu">Front-line support agents</td></tr>
