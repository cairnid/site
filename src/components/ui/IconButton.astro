---
import Icon from '../Icon.astro';

type Props = {
  href?: string;
  icon: string;
  label: string;
  size?: 'sm' | 'md';
  variant?: 'default' | 'ghost';
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  class?: string;
  [key: string]: unknown;
};

const {
  href,
  icon,
  label,
  size = 'md',
  variant = 'default',
  type = 'button',
  disabled = false,
  class: className = '',
  ...rest
} = Astro.props;

const classes = [
  'cn-icon-btn',
  size === 'sm' ? 'cn-icon-btn--sm' : '',
  variant === 'ghost' ? 'cn-icon-btn--ghost' : '',
  className,
].filter(Boolean).join(' ');

const common = {
  class: classes,
  'aria-label': label,
  title: label,
  ...rest,
};
---
{href ? (
  <a href={href} {...common}>
    <Icon name={icon} size={size === 'sm' ? 14 : 16} />
  </a>
) : (
  <button type={type} disabled={disabled} {...common}>
    <Icon name={icon} size={size === 'sm' ? 14 : 16} />
  </button>
)}
