---
import '../styles/app.css';
import CairnMark from '../components/CairnMark.astro';
import Icon from '../components/Icon.astro';
import { getStarCount, formatStars, GITHUB_URL } from '../lib/github';

const stars = await getStarCount();

type Props = {
  title: string;
  description: string;
  active?: string;
  ctaLabel?: string;
  ctaHref?: string;
  mainClass?: string;
  bodyClass?: string;
  forceTheme?: 'dark' | 'light';
  ogImage?: string;
  noindex?: boolean;
};

const {
  title,
  description,
  active = '',
  ctaLabel = 'Read the docs',
  ctaHref = '/docs/',
  mainClass = '',
  bodyClass = '',
  forceTheme,
  ogImage = '/og-cairnid.png',
  noindex = false,
} = Astro.props;

const fullTitle = title === 'CairnID' ? title : `CairnID  -  ${title}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'CairnID',
  url: 'https://cairnid.com',
  logo: 'https://cairnid.com/cairn-mark.svg',
  description: 'Strict, auditable OpenID Connect and OAuth identity you can self-host or run as managed Cloud.',
  sameAs: ['https://github.com/cairnid/cairnid'],
};

const navLinks = [
  { id: 'product', href: '/#capabilities', label: 'Product' },
  { id: 'surfaces', href: '/surfaces/', label: 'Surfaces' },
  { id: 'protocol', href: '/protocol/', label: 'Protocol' },
  { id: 'cloud', href: '/cloud/', label: 'Cloud' },
  { id: 'docs', href: '/docs/', label: 'Docs' },
];

const footerColumns = [
  {
    title: 'Product',
    links: [
      { href: '/#capabilities', label: 'Specification' },
      { href: '/surfaces/', label: 'Surfaces' },
      { href: '/protocol/', label: 'Protocol' },
      { href: '/cloud/', label: 'Cloud' },
    ],
  },
  {
    title: 'Docs',
    links: [
      { href: '/docs/architecture/', label: 'Architecture' },
      { href: '/docs/api/', label: 'API reference' },
      { href: '/docs/deployment/', label: 'Deployment' },
      { href: '/docs/security/', label: 'Security posture' },
    ],
  },
  {
    title: 'Project',
    links: [
      { href: 'https://github.com/cairnid/cairnid', label: 'GitHub' },
      { href: '/ui/', label: 'Design system' },
      { href: '/docs/changelog/', label: 'Changelog' },
      { href: '/docs/release-gates/', label: 'Release gates' },
    ],
  },
];
---

<!doctype html>
<html lang="en" data-theme={forceTheme ?? 'light'} data-theme-lock={forceTheme ? 'true' : undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,follow" />}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#faf8f3" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#1a1714" />

    <!-- Critical brand faces fetch in parallel with the CSS rather than after it. -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/Archivo-Regular.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/Archivo-Bold.woff2" crossorigin />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="CairnID" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script is:inline>
      (function () {
        var root = document.documentElement;
        if (root.getAttribute('data-theme-lock')) { return; }
        try {
          var stored = localStorage.getItem('cairnid-theme');
          root.dataset.theme = stored === 'dark' ? 'dark' : 'light';
        } catch (e) {
          root.dataset.theme = 'light';
        }
      })();
    </script>
    <slot name="head" />
  </head>
  <body class={bodyClass || undefined}>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="mast">
      <div class="wrap">
        <a class="brand" href="/" aria-label="CairnID home">
          <CairnMark size={25} />
          <span>Cairn<span class="id">ID</span></span>
        </a>
        <nav class="nav" aria-label="Primary">
          {navLinks.map((link) => (
            <a href={link.href} class={active === link.id ? 'active' : undefined} aria-current={active === link.id ? 'page' : undefined}>
              {link.label}
            </a>
          ))}
        </nav>
        <div class="right">
          {!forceTheme && (
            <button class="icon-toggle" type="button" data-theme-toggle aria-label="Toggle theme" aria-pressed="false">
              <Icon name="moon" class="theme-toggle__moon" size={17} />
              <Icon name="sun" class="theme-toggle__sun" size={17} />
            </button>
          )}
          <a class="ghbadge" href={GITHUB_URL} aria-label="CairnID on GitHub">
            <Icon name="github" size={15} /><span class="lbl">GitHub</span>
            {stars !== null && (
              <span class="ct"><Icon name="star" size={11} />{formatStars(stars)}</span>
            )}
          </a>
          <a class="cn-btn cn-btn--primary cn-btn--sm header-cta" href={ctaHref}>{ctaLabel}</a>
          <button class="icon-toggle nav-toggle" type="button" data-nav-toggle aria-label="Open menu" aria-expanded="false" aria-controls="nav-mobile">
            <Icon name="menu" size={18} />
          </button>
        </div>
      </div>
      <div class="nav-mobile" id="nav-mobile" data-open="false">
        <div class="wrap nav-mobile__inner">
          {navLinks.map((link) => (
            <a href={link.href} aria-current={active === link.id ? 'page' : undefined}>{link.label}</a>
          ))}
          <a class="cn-btn cn-btn--primary nav-mobile__cta" href={ctaHref}>{ctaLabel}</a>
        </div>
      </div>
    </header>

    <main id="main" class={mainClass}>
      <slot />
    </main>

    <footer class="foot">
      <div class="wrap">
        <div class="foot-grid">
          <div class="foot-about">
            <a class="brand" href="/" aria-label="CairnID home">
              <CairnMark size={23} />
              <span>Cairn<span class="id">ID</span></span>
            </a>
            <p>A small, auditable identity provider for teams that want strict OIDC without a heavy platform.</p>
          </div>
          {footerColumns.map((column) => (
            <nav aria-label={column.title}>
              <h4>{column.title}</h4>
              {column.links.map((link) => (
                <a class="fl" href={link.href}>{link.label}</a>
              ))}
            </nav>
          ))}
        </div>
        <div class="foot-bottom">
          <span>(c) 2026 CairnID  -  Apache-2.0</span>
          <span class="mono">Strict OIDC  -  Clear operations  -  Small surface</span>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        function syncToggles() {
          var dark = document.documentElement.dataset.theme === 'dark';
          document.querySelectorAll('[data-theme-toggle]').forEach(function (b) {
            b.setAttribute('aria-pressed', String(dark));
          });
        }
        syncToggles();
        document.addEventListener('click', function (event) {
          var toggle = event.target.closest('[data-theme-toggle]');
          if (toggle) {
            var root = document.documentElement;
            var next = root.dataset.theme === 'dark' ? 'light' : 'dark';
            root.classList.add('theme-switching');
            root.dataset.theme = next;
            // Force a synchronous restyle so every var-backed surface re-resolves at once.
            document.body.style.display = 'none';
            void document.body.offsetHeight;
            document.body.style.display = '';
            requestAnimationFrame(function () { root.classList.remove('theme-switching'); });
            try { localStorage.setItem('cairnid-theme', next); } catch (e) {}
            syncToggles();
            return;
          }
          var navToggle = event.target.closest('[data-nav-toggle]');
          if (navToggle) {
            var panel = document.getElementById('nav-mobile');
            if (!panel) return;
            var open = panel.getAttribute('data-open') === 'true';
            panel.setAttribute('data-open', String(!open));
            navToggle.setAttribute('aria-expanded', String(!open));
          }
        });
      })();
    </script>
  </body>
</html>
