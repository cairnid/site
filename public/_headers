# Cloudflare Workers static-assets headers.
# Content-hashed build assets and stable font/shape assets are immutable —
# cache them hard so repeat visits don't re-validate. HTML stays on the default
# (revalidate) policy so deploys are picked up immediately.

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/shapes/*
  Cache-Control: public, max-age=31536000, immutable
