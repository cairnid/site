{
  "name": "@cairnid/site",
  "private": true,
  "license": "Apache-2.0",
  "description": "Standalone Astro public site and documentation for Cairn Identity.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun --bun astro dev",
    "check": "bun --bun astro check && bun scripts/check-public-content.ts",
    "build": "bun --bun astro build",
    "preview": "bun --bun astro preview",
    "deploy": "bun run build && bun --bun wrangler deploy",
    "deploy:dry-run": "bun run build && bun --bun wrangler deploy --dry-run"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/markdown-remark": "7.2.0",
    "@cloudflare/workers-types": "^4.20260626.1",
    "@types/node": "26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.2",
    "subset-font": "^2.5.0",
    "typescript": "6.0.3",
    "wrangler": "^4.104.0"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@iconify-json/bx": "^1.2.3",
    "@iconify-json/bxl": "^1.2.4",
    "@paper-design/shaders-react": "^0.0.76",
    "@tailwindcss/vite": "^4.3.1",
    "astro-icon": "^1.1.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1"
  }
}
